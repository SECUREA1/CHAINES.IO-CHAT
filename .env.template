# Copy this to .env and edit values (do NOT commit .env to git).

# NETWORK: "testnet" or "mainnet"
NETWORK=testnet

# Absolute path on the host that will be mounted to /work inside container
WORKING_DIR_EXTERNAL=/absolute/path/to/nft-dropper-work

# Price per token in ADA (integer)
TOKEN_PRICE=10

# Max tokens a buyer can purchase in a single transaction
TOKEN_MAX_AMOUNT=5

# Seller receiving address (for testnet use a testnet address)
SELLER_ADDRESS=addr_test1...REPLACE_WITH_YOUR_ADDRESS

# Docker volume name for node IPC (default used by docker-compose)
IPC_VOLUME_NAME=nft-dropper-composed_node-ipc

# hCaptcha (optional)
USE_CAPTCHA=false
HCAPTCHA_SITEKEY=
HCAPTCHA_SECRET=
